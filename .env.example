# BNBClaw Environment Variables
# Copy this to .env and fill in your Telegram token.
# All other keys can be set up via chat — just send /start to your bot!

# ── Required ──────────────────────────────────────────────
# Telegram Bot (message @BotFather to get a token)
TELEGRAM_BOT_TOKEN=

# ── Optional (can be set via /setup in chat instead) ──────
# Binance API (scoped: spot+futures trade enabled, withdraw DISABLED)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# LLM Brain (enables natural language AI chat)
# Works with OpenRouter, OpenAI, Groq, Together, or any OpenAI-compatible API
# LLM_API_KEY=
# LLM_BASE_URL=https://openrouter.ai/api
# LLM_MODEL=google/gemini-2.0-flash

# ── Advanced (rarely needed) ─────────────────────────────
# Encryption key for API key storage (auto-generated on first run if empty)
# ENCRYPTION_KEY=

# TradingView Webhook (optional)
# WEBHOOK_SECRET=
# WEBHOOK_PORT=3000

# Telegram Chat ID (auto-detected from first message if empty)
# TELEGRAM_CHAT_ID=

# Default Settings (override via /setup or chat)
# DEFAULT_USDT_FLOOR=500
# DEFAULT_LEVERAGE=3
# DEFAULT_RISK_PER_TRADE=0.05
# DEFAULT_BNB_BUY_THRESHOLD=50
# DEFAULT_HEDGE_RATIO=0.85
