# BNBClaw Environment Variables
# Copy this to .env and fill in your values

# Binance API (scoped: spot+futures trade enabled, withdraw DISABLED)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Encryption key for API key storage (auto-generated on first run if empty)
ENCRYPTION_KEY=

# TradingView Webhook (optional)
WEBHOOK_SECRET=
WEBHOOK_PORT=3000

# Telegram Bot (message @BotFather to get a token)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM Brain (optional — enables natural language chat instead of commands only)
# Works with OpenAI, OpenRouter, Groq, Together, or any OpenAI-compatible API
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-4o-mini

# Default Settings
DEFAULT_USDT_FLOOR=500
DEFAULT_LEVERAGE=3
DEFAULT_RISK_PER_TRADE=0.05
DEFAULT_BNB_BUY_THRESHOLD=50
DEFAULT_HEDGE_RATIO=0.85
