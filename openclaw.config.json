{
  "name": "BNBClaw",
  "description": "BNB-first OpenClaw assistant for Binance Earn, reward handling, wallet cleanup, and hedge guidance without selling spot BNB.",
  "version": "1.0.0",
  "plugins": [
    {
      "id": "bnbclaw",
      "source": "./dist/plugin.js",
      "manifest": "./openclaw.plugin.json",
      "config": {}
    }
  ],
  "heartbeat": {
    "enabled": true,
    "checks": [
      { "name": "scheduled-jobs", "interval": "30s" },
      { "name": "reward-check", "interval": "30m" },
      { "name": "dust-cleanup", "interval": "7d" }
    ]
  },
  "permissions": {
    "network": true,
    "filesystem": false,
    "shell": false
  }
}
